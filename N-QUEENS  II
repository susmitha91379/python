class Solution:
    def totalNQueens(self, n: int) -> int:
        # Sets to keep track of attacked positions
        col = set()
        diag1 = set()   # row - col
        diag2 = set()   # row + col

        count = 0

        # Backtracking function
        def backtrack(row):
            nonlocal count

            # If all queens are placed
            if row == n:
                count += 1
                return

            # Try placing queen in every column
            for c in range(n):

                # Check if position is safe
                if c in col or (row - c) in diag1 or (row + c) in diag2:
                    continue

                # Place queen
                col.add(c)
                diag1.add(row - c)
                diag2.add(row + c)

                # Move to next row
                backtrack(row + 1)

                # Remove queen (backtrack)
                col.remove(c)
                diag1.remove(row - c)
                diag2.remove(row + c)

        backtrack(0)

        return count
