class Solution:
    def insert(self, root, key):
        # code here 
        if(root.data == key):
            return root
        temp = root
        while(temp is not None):
            if(key > temp.data):
                if(temp.right == None):
                    temp.right = Node(key)
                    break
                temp = temp.right
            elif(key < temp.data):
                if(temp.left == None):
                    temp.left = Node(key)
                    break
                temp = temp.left
        return root
