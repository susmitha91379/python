class Solution:
    def isCyclic(self, V, edges):
        def dfs(node):
            vis[node] = 1
            pathVis[node] = 1
            for adjNode in adj[node]:
                if(vis[adjNode] == 0):
                    if(dfs(adjNode) == True):
                        return True
                elif(vis[adjNode] == 1):
                    if(pathVis[adjNode] == 1):
                        return True
            pathVis[node] = 0
            return
        adj = []
        for _ in range(V):
            adj.append([])
        for u,v in edges:
            adj[u].append(v)
        vis = [0]*V
        pathVis = [0]*V
        for n in range(0,V):
            if(vis[n] == 0):
                if(dfs(n) == True):
                    return True
        return False
