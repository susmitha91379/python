class Solution:
    def threeSum(self, nums: list[int]) -> list[list[int]]:
        s = set()
        n=len(nums) #O(N**3)
        for i in range(0,n):
            for j in range(i+1,n):
                for k in range(j+1,n):
                    if(nums[i]+nums[j]+nums[k] == 0):
                        lst = [nums[i],nums[j],nums[k]]
                        lst.sort()
                        s.add(tuple(lst))
        ans = []
        for t in s:
            ans.append(list(t))
        return ans
