class Solution:
    def generate(self, numRows: int) -> List[List[int]]:
        triangle = []

        for i in range(numRows):
            row = []
            value = 1

            for j in range(i + 1):
                row.append(value)
                value = value * (i - j) // (j + 1)

            triangle.append(row)

        return triangle
        
