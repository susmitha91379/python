# return the Kth largest element in the given BST rooted at 'root'
class Solution:
    def kthLargest(self,root, k):
        #your code here
        def inorder(root,arr):
            if(root == None):
                return
            inorder(root.left,arr)
            arr.append(root.data)
            inorder(root.right,arr)
        arr = []
        inorder(root,arr)
        return arr[-k]
